FLASK_DEBUG=false
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Use a long random value in production.
JWT_SECRET_KEY=replace-with-strong-secret
JWT_ACCESS_TOKEN_EXPIRES_DAYS=7

# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# Database URL (Render Postgres recommended for production).
# Example:
# DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname

# Mail credentials for OTP delivery.
MAIL_USERNAME=your-email@gmail.com
MAIL_EMAIL=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# Keep false in production.
ALLOW_OTP_IN_RESPONSE=false

# Optional AI service key (used by analyzer features, not OTP).
GROQ_API_KEY=your-groq-key
