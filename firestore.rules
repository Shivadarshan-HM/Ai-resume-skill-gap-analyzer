rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function hasOnlyKeys(data, allowedKeys) {
      return data.keys().hasOnly(allowedKeys);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId)
        && hasOnlyKeys(
          request.resource.data,
          [
            'full_name',
            'email',
            'bio',
            'phone',
            'location',
            'linkedin_url',
            'github_url',
            'portfolio_url',
            'photo_url',
            'createdAt',
            'updatedAt'
          ]
        );
      allow delete: if false;
    }

    match /resume_analyses/{analysisId} {
      allow read: if isOwner(resource.data.uid);
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid
        && hasOnlyKeys(
          request.resource.data,
          [
            'uid',
            'role',
            'prompt',
            'sourceFileName',
            'summary',
            'analysis',
            'required_skills',
            'found_skills',
            'missing_skills',
            'highlighted_skills',
            'suggestions',
            'match_score',
            'createdAt',
            'updatedAt'
          ]
        );
      allow update: if isOwner(resource.data.uid)
        && request.resource.data.uid == resource.data.uid
        && hasOnlyKeys(
          request.resource.data,
          [
            'uid',
            'role',
            'prompt',
            'sourceFileName',
            'summary',
            'analysis',
            'required_skills',
            'found_skills',
            'missing_skills',
            'highlighted_skills',
            'suggestions',
            'match_score',
            'createdAt',
            'updatedAt'
          ]
        );
      allow delete: if isOwner(resource.data.uid);
    }

    match /chat_messages/{messageId} {
      allow read: if isOwner(resource.data.uid);
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid
        && hasOnlyKeys(request.resource.data, ['uid', 'role', 'content', 'createdAt']);
      allow update: if false;
      allow delete: if isOwner(resource.data.uid);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
